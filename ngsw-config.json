{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    },
    {
      "name": "imagenes-excursiones",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "cacheQueryOptions": { "ignoreVary": true },
      "resources": {
        "urls": ["https://picsum.photos/**", "https://*.picsum.photos/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-excursiones",
      "urls": ["/**/api/v1/**/excursiones", "/**/api/v1/**/excursiones/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "3s"
      }
    }
  ]
}
